# Copy this to .env and fill it in. .env is gitignored, never commit it.

# Redis, the system of record. Use rediss:// for TLS.
REDIS_URL='redis://default:password@host:port'
# All keys are namespaced under this prefix so the app can share a Redis DB safely.
REDIS_PREFIX=peio:

# Admin area (/admin) HTTP basic auth.
ADMIN_USER=gabriel
ADMIN_PASS=change-me

# Contact email (optional). Leave SMTP_* blank to just store messages in Redis
# and read them in /admin/inbox. For Gmail, use an App Password.
CONTACT_TO=you@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Deploy target for deploy/deploy.sh (gcloud).
ZONE=us-central1-a
INSTANCE=your-vm-name
PROJECT=your-gcp-project
REMOTE_DIR=platformengineer.io
# Path to the gcloud binary if it is not on PATH.
GCLOUD=gcloud
